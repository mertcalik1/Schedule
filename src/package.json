{
    "name":  "your-schedule",
    "version":  "1.0.0",
    "description":  "A personal calendar, reminder, routine, and time analysis app.",
    "author":  "Mert C",
    "main":  "main.js",
    "private":  true,
    "scripts":  {
                    "start":  "electron .",
                    "check":  "node --check app.js \u0026\u0026 node --check main.js",
                    "package:mac":  "electron-builder --mac",
                    "package:win":  "electron-builder --win",
                    "cap:add:android":  "pnpm run build:web \u0026\u0026 cap add android",
                    "cap:add:ios":  "pnpm run build:web \u0026\u0026 cap add ios",
                    "cap:sync":  "pnpm run build:web \u0026\u0026 cap sync",
                    "cap:open:android":  "cap open android",
                    "cap:open:ios":  "cap open ios",
                    "build:web":  "node scripts/build-web.cjs"
                },
    "build":  {
                  "appId":  "com.mert.timecalendar",
                  "productName":  "Your Schedule",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "index.html",
                                "app.js",
                                "styles.css",
                                "main.js",
                                "manifest.webmanifest",
                                "sw.js",
                                "assets/**/*",
                                "package.json"
                            ],
                  "mac":  {
                              "category":  "public.app-category.productivity",
                              "target":  [
                                             "dmg",
                                             "zip"
                                         ],
                              "icon":  "assets/logo.png"
                          },
                  "win":  {
                              "target":  "nsis",
                              "icon":  "assets/logo.ico"
                          }
              },
    "devDependencies":  {
                            "@capacitor/android":  "^8.4.1",
                            "@capacitor/cli":  "^8.4.1",
                            "@capacitor/core":  "^8.4.1",
                            "@capacitor/ios":  "^8.4.1",
                            "electron":  "^31.7.7",
                            "electron-builder":  "^26.15.3"
                        }
}
